// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  username     String        @unique // Уникальный логин (например, "elena")
  passwordHash String        // Захешированный пароль
  name         String        // Имя мастера (для приветствия)
  clients      Client[]
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Client {
  id           String        @id @default(uuid())
  userId       String?       // Опционально для безопасного перехода
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String        // Имя клиента
  phone        String?       // Номер телефона (опционально)
  notes        String?       // Заметки о предпочтениях клиента
  appointments Appointment[] // Записи клиента
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Appointment {
  id          String            @id @default(uuid())
  userId      String?           // Опционально для безопасного перехода
  user        User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String?           // Ссылка на клиента (может быть null)
  client      Client?           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  clientName  String
  clientPhone String?
  service     String            // Название услуги (например, "Маникюр + гель-лак")
  dateTime    DateTime          // Дата и время записи
  price       Float             // Стоимость
  location    String            // "HOME" (дома) или "SALON" (в салоне)
  status      String            // "PLANNED" (запланирована), "COMPLETED" (выполнена), "CANCELLED" (отменена)
  notes       String?           // Заметка к конкретной записи
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  @@index([dateTime])
}
